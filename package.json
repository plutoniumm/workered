  "devDependencies": {
    "@rollup/plugin-commonjs": "22.0.1",
    "@rollup/plugin-node-resolve": "13.3.0",
    "express": "4.18.1",
    "rollup": "2.77.0",
    "rollup-plugin-terser": "7.0.2"
  }
}